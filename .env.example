# ── Agent Affiliation — Variables d'environnement ─────────────────────────────
# Copiez ce fichier en .env pour un usage local, ou configurez dans Railway > Variables

# ── Amazon Affilié ────────────────────────────────────────────────────────────
# Votre tag d'affiliation Amazon (deja rempli)
AMAZON_TAG=shopforyou099-21

# Filtres produits (optionnel — valeurs par defaut)
MIN_RATING=4.0
MAX_PRICE=50.0
MIN_REVIEWS=100

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# Adresse Gmail qui envoie le rapport
EMAIL_FROM=votre.email@gmail.com

# Adresse qui recoit le rapport (peut etre identique)
EMAIL_TO=votre.email@gmail.com

# Mot de passe d'application Gmail (PAS votre vrai mot de passe)
# Generer sur : https://myaccount.google.com/apppasswords
# Activer d'abord la validation en 2 etapes, puis creer un "Mot de passe d'application"
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# ── TikTok Session ────────────────────────────────────────────────────────────
# Valeur du cookie "sessionid" de TikTok
# Comment recuperer :
#   1. Ouvrez tiktok.com dans Chrome et connectez-vous
#   2. F12 > Application > Cookies > https://www.tiktok.com
#   3. Copiez la valeur de "sessionid"
TIKTOK_SESSION_ID=votre_session_id_ici
